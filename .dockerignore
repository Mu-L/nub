# Keep the Docker build context small: the in-container build compiles from source
# and installs deps fresh, so host build artifacts and checkouts must not be copied.
target/
node_modules/
.repos/
.git/
.vercel/
site/node_modules/
site/.next/
**/*.log

# Generic production-bundle exclusions, maintained by `untracked`
# (pnpm run dockerignore:update). Custom rules above are preserved; the
# whitelist in package.json rescues the load-bearing .cargo configs
# (crates/nub-native/.cargo routes in-container build output to the
# shared target dir — docker-smoke builders depend on it).
