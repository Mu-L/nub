# npm-cli soak window (npm >= 11.17, DAYS) — governs the root npm ci that
# wpt-worker and CI run. Managed by scripts/soak/soak.mts.
#
# The pnpm-side soak (minimumReleaseAge, catalog) lives in
# tools/pnpm-workspace.yaml, NOT here: pnpm only honors minimumReleaseAge from
# a workspace yaml, and nub treats a workspace yaml beside a pnpm lockfile as
# a workspace-root marker — one at the REPO root makes every in-repo nub
# invocation inherit the root package.json engines (>=22.15) and redirects the
# test matrix's older-Node legs (the engines-redirect false-green
# tests/node-matrix/run.sh guards against). Anchoring it in tools/ keeps the
# boundary below anything the tests walk.
min-release-age=7
